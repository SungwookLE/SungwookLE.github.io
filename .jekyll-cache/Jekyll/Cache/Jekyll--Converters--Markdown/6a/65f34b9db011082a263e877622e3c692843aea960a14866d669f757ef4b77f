<h3 id="3-1-1м∞®мЫР-мєЉлІМ">3-1. 1м∞®мЫР мєЉлІМ</h3>
<p>1м∞®мЫР мД†нШХ мєЉлІМ, нЭФнЮИ л≥ілКФ мєЉлІМ нХДнД∞ мИШмЛЭ нШХнГЬк∞А мХДлЛИк≥† лґДмВ∞мЭШ к∞Ам§СмєШ нПЙкЈ†мЭД мЭімЪ©нХШмЧђ к∞ТмЭД л≥ім†ХнХШлКФ нШХнГЬл°Ь мИШмЛЭмЭД мЮСмД±нХШмШАлЛ§. мИШмЛЭмЭШ нШХнГЬлІМ лЛ§л•Љ лњР <code class="language-plaintext highlighter-rouge">System Mtx A=1 мЭік≥†, input Mtx B =1, Output Mtx C =1</code>мЭЄ мєЉлІМнХДнД∞мЩА м†ХнЩХнЮИ к∞ЩлЛ§.</p>
<div class="language-c++ highlighter-rouge"><div class="highlight"><pre class="highlight"><code><span class="k">template</span> <span class="o">&lt;</span><span class="k">typename</span> <span class="nc">T</span><span class="p">&gt;</span>
<span class="k">class</span> <span class="nc">Kalman</span><span class="p">{</span>
    <span class="nl">public:</span>
    <span class="n">Kalman</span><span class="p">(</span><span class="n">T</span> <span class="n">covariance_measurement_</span><span class="p">,</span> <span class="n">T</span> <span class="n">covariance_prediction_</span><span class="p">){</span>
        <span class="n">covariance_measurement</span> <span class="o">=</span> <span class="n">covariance_measurement_</span><span class="p">;</span>
        <span class="n">covariance_prediction</span> <span class="o">=</span> <span class="n">covariance_prediction_</span><span class="p">;</span>
    <span class="p">}</span>

    <span class="kt">void</span> <span class="n">measure_upate</span><span class="p">(</span><span class="n">T</span> <span class="n">mean_measure</span><span class="p">){</span>
        <span class="c1">// л≤†мЭім¶И л≤ХмєЩмЧР лФ∞лЭЉ м°∞к±ілґАнЩХл•†мЧР лФ∞лЭЉ мЧЕлН∞мЭінКЄ лРЬлЛ§.</span>
        <span class="n">T</span> <span class="n">mean_now</span> <span class="o">=</span> <span class="n">mean</span><span class="p">;</span>
        <span class="n">T</span> <span class="n">covariance_now</span> <span class="o">=</span> <span class="n">covariance</span><span class="p">;</span>


        <span class="n">T</span> <span class="n">new_covariance</span> <span class="o">=</span> <span class="mi">1</span><span class="o">/</span><span class="p">(</span><span class="mi">1</span><span class="o">/</span><span class="n">covariance_now</span><span class="o">+</span> <span class="mi">1</span><span class="o">/</span><span class="n">covariance_measurement</span> <span class="p">);</span>
        <span class="n">T</span> <span class="n">new_mean</span> <span class="o">=</span> <span class="p">(</span><span class="n">mean_now</span> <span class="o">*</span> <span class="mi">1</span><span class="o">/</span><span class="n">covariance_now</span> <span class="o">+</span> <span class="n">mean_measure</span><span class="o">*</span><span class="mi">1</span><span class="o">/</span><span class="n">covariance_measurement</span><span class="p">)</span>
                     <span class="o">/</span> <span class="p">(</span><span class="mi">1</span><span class="o">/</span><span class="n">new_covariance</span><span class="p">);</span>

        <span class="n">mean</span> <span class="o">=</span> <span class="n">new_mean</span><span class="p">;</span>
        <span class="n">covariance</span> <span class="o">=</span> <span class="n">new_covariance</span><span class="p">;</span>

        <span class="n">std</span><span class="o">::</span><span class="n">cout</span> <span class="o">&lt;&lt;</span> <span class="s">"update: "</span> <span class="o">&lt;&lt;</span> <span class="s">"["</span> <span class="o">&lt;&lt;</span> <span class="n">mean</span> <span class="o">&lt;&lt;</span> <span class="s">","</span> <span class="o">&lt;&lt;</span><span class="n">covariance</span> <span class="o">&lt;&lt;</span> <span class="s">"]"</span> <span class="o">&lt;&lt;</span> <span class="n">std</span><span class="o">::</span><span class="n">endl</span><span class="p">;</span>

    <span class="p">}</span>

    <span class="kt">void</span> <span class="n">model_prediction</span><span class="p">(</span><span class="n">T</span> <span class="n">input</span><span class="p">){</span>
        <span class="c1">//input мЭі лУ§мЦімШімЧР лФ∞лЭЉ м†ДнЩХл•† л≤ХмєЩмЧР мЭШк±∞нХШмЧђ м†Дм≤і лґДмВ∞мЭА (+)к∞А лРЬлЛ§.</span>
        <span class="n">mean</span> <span class="o">=</span> <span class="n">mean</span> <span class="o">+</span> <span class="n">input</span><span class="p">;</span>
        <span class="n">covariance</span> <span class="o">=</span> <span class="n">covariance</span> <span class="o">+</span> <span class="n">covariance_prediction</span> <span class="p">;</span>

        <span class="n">std</span><span class="o">::</span><span class="n">cout</span> <span class="o">&lt;&lt;</span> <span class="s">"predict: "</span> <span class="o">&lt;&lt;</span> <span class="s">"["</span> <span class="o">&lt;&lt;</span> <span class="n">mean</span> <span class="o">&lt;&lt;</span> <span class="s">","</span> <span class="o">&lt;&lt;</span><span class="n">covariance</span> <span class="o">&lt;&lt;</span> <span class="s">"]"</span> <span class="o">&lt;&lt;</span> <span class="n">std</span><span class="o">::</span><span class="n">endl</span><span class="p">;</span>
    <span class="p">}</span>

    <span class="nl">private:</span>
    <span class="n">T</span> <span class="n">covariance_measurement</span><span class="p">;</span>
    <span class="n">T</span> <span class="n">covariance_prediction</span><span class="p">;</span>
    <span class="n">T</span> <span class="n">mean</span><span class="o">=</span><span class="mi">0</span><span class="p">;</span>
    <span class="n">T</span> <span class="n">covariance</span><span class="o">=</span><span class="mf">1000.0</span><span class="p">;</span>
<span class="p">};</span>

<span class="kt">int</span> <span class="nf">main</span><span class="p">(){</span>

    <span class="n">std</span><span class="o">::</span><span class="n">vector</span><span class="o">&lt;</span><span class="kt">double</span><span class="o">&gt;</span> <span class="n">inputs</span><span class="o">=</span><span class="p">{</span><span class="mi">1</span><span class="p">,</span><span class="mi">1</span><span class="p">,</span><span class="mi">2</span><span class="p">,</span><span class="mi">1</span><span class="p">,</span><span class="mi">1</span><span class="p">};</span>
    <span class="n">std</span><span class="o">::</span><span class="n">vector</span><span class="o">&lt;</span><span class="kt">double</span><span class="o">&gt;</span> <span class="n">measurements</span><span class="o">=</span><span class="p">{</span><span class="mi">5</span><span class="p">,</span><span class="mi">6</span><span class="p">,</span><span class="mi">7</span><span class="p">,</span><span class="mi">9</span><span class="p">,</span><span class="mi">10</span><span class="p">};</span>

    <span class="kt">double</span> <span class="n">measure_cov</span> <span class="o">=</span> <span class="mi">4</span><span class="p">;</span>
    <span class="kt">double</span> <span class="n">model_cov</span> <span class="o">=</span> <span class="mi">2</span><span class="p">;</span>

    <span class="n">Kalman</span><span class="o">&lt;</span><span class="kt">double</span><span class="o">&gt;</span> <span class="n">kf</span><span class="p">(</span><span class="n">measure_cov</span><span class="p">,</span> <span class="n">model_cov</span><span class="p">);</span>

    <span class="k">for</span><span class="p">(</span><span class="kt">int</span> <span class="n">i</span> <span class="o">=</span><span class="mi">0</span> <span class="p">;</span> <span class="n">i</span> <span class="o">&lt;</span> <span class="n">measurements</span><span class="p">.</span><span class="n">size</span><span class="p">();</span> <span class="o">++</span><span class="n">i</span><span class="p">){</span>
        <span class="n">kf</span><span class="p">.</span><span class="n">measure_upate</span><span class="p">(</span><span class="n">measurements</span><span class="p">[</span><span class="n">i</span><span class="p">]);</span>
        <span class="n">kf</span><span class="p">.</span><span class="n">model_prediction</span><span class="p">(</span><span class="n">inputs</span><span class="p">[</span><span class="n">i</span><span class="p">]);</span>
    <span class="p">}</span>

    <span class="k">return</span> <span class="mi">0</span><span class="p">;</span>
<span class="p">}</span>
</code></pre></div></div>

<h3 id="3-2-лЛ§м∞®мЫР-мєЉлІМ">3-2. лЛ§м∞®мЫР мєЉлІМ</h3>
<ul>
  <li>hidden state (observable)
лЛ§м∞®мЫРмЭШ Stateл•Љ мґФм†ХнХ† лХМ, л™®лУ† Stateл•Љ мґФм†ХнХ† мИШ мЮИлКФ к≤ГмЭА мХДлЛИлЛ§. лВШлКФ мґФм†ХкЄ∞мЩА нХДнД∞л•Љ кµђлґДнХШмЧђ лґАл•ілКФ к≤ГмЭД мД†нШЄнХШлКФлН∞, мґФм†ХкЄ∞лКФ <code class="language-plaintext highlighter-rouge">observability</code>к∞А мЮИмЦі мЄ°м†Хк∞ТмЬЉл°Ь лВік∞А кµђнХШк≥†мЮР нХШлКФ stateл•Љ міИкЄ∞к∞Тк≥Љ кіАк≥ДмЧЖмЭі мґФм†ХнХ† мИШ мЮИлКФ кіАмЄ°кЄ∞л•Љ мЭШлѓЄнХШк≥†(observer), нХДнД∞лКФ <code class="language-plaintext highlighter-rouge">observability</code>к∞А мЧЖмЦі stateмЭШ лЕЄмЭім¶Ил•Љ м†Ьк±∞нХШлКФ(мШИмЛЬ: moving sum filter) мЧ≠нХ†лІМмЭД мИШнЦЙнХШлКФ к≤ГмЭД лІРнХЬлЛ§. мЭілЯ∞ к≤љмЪ∞ міИкЄ∞к∞ТмЭШ мШ§м∞®лКФ кЈєл≥µмЭі мХИлРШк≥† <code class="language-plaintext highlighter-rouge">costant error</code>л°Ь м°імЮђнХШк≤М лРЬлЛ§.</li>
  <li>мШИл•Љ лУ§мЦіл≥іл©і, мЖНлПДлІМмЬЉл°Ь мЬДмєШл•Љ мґФм†ХнХШк≥†мЮР нХ† лХМ, міИкЄ∞ мЬДмєШл•Љ л™®л•іл©і мґФм†ХнХЬ мЬДмєШлКФ лВік∞А мД§м†ХнХЬ міИкЄ∞ мЬДмєШмЩА лђЉм≤імЭШ мЛ§м†Ь міИкЄ∞мЬДмєШ лІМнБЉмЭШ міИкЄ∞ мЧРлЯђк∞А м°імЮђнХШлКФлН∞ мЭілКФ <code class="language-plaintext highlighter-rouge">constant error</code>л°Ь лВ®к≤М лРЬлЛ§.
observabilityлКФ мД†нШХмЛЬмК§нЕЬ мЭіл°†мЭД м∞Єк≥†нХШкЄЄ л∞ФлЮАлЛ§. <code class="language-plaintext highlighter-rouge">dot_x = Ax+bu, y=Cx</code>л°Ь мЭіл£®мЦімІД мД†нШХ мЛЬмК§нЕЬмЧРмДЬ AмЩА C mtxк∞ДмЭШ rank кіАк≥Дл•Љ нЖµнХЬ observable information мЧђлґА(observability)лКФ мЦілЦїк≤М нЩХмЭЄнХ† мИШ мЮИк≥† к∞ЬмД†лР† мИШ мЮИлКФмІА л∞∞мЪЄ мИШ мЮИлЛ§.</li>
  <li>hidden stateлКФ observable кіАк≥Дл•Љ мЭімЪ©нХШмЧђ мґФм†ХнХ† мИШ мЮИлКФ stateл•Љ лІРнХШк≥† мґФм†ХкЄ∞лКФ лМАлґАлґД мДЉмДЬл°Ь к≥ДмЄ°мЭі лРШмІА мХИнЭФгДі к≤љмЪ∞мЧР нХДмЪФнХЬ к≤љмЪ∞к∞А лІОмХДмДЬ, мЪ∞л¶ђк∞А нХДнД∞к∞А мХДлЛМ мґФм†ХкЄ∞л•Љ мД§к≥ДнХ† лЦДлКФ лМАлґАлґДмЭШ к≤љмЪ∞к∞А <code class="language-plaintext highlighter-rouge">hidden state</code>л•Љ мґФм†ХнХШкЄ∞ мЬДнХ®мЭілЭЉк≥† л≥Љ мИШ мЮИлЛ§.</li>
  <li>мЄ°м†Хк∞Тк≥Љ л™®лНЄмЭі Correlation кіАк≥ДмЧР мЮИлКФ мєЉлІМ мЛЬмК§нЕЬ лґДмВ∞ мЭілПЩ к≥Љм†ХмЭД XлКФ мҐЕл∞©нЦ• мЬДмєШ, $\dot X$лКФ мҐЕл∞©нЦ• мЖНлПДмЭік≥†, мЄ°м†Хк∞ТмЭА мҐЕл∞©нЦ• мЬДмєШ(X)мЭЄ мХДлЮШ мШИмЛЬл°Ь мВінОіл≥імЮР.
    <blockquote>
      <p>л™®лНЄ eq.
 ${X_{k+1} = X_k + dt* \dot X_k }$<br />
мХДмЫГнТЛ eq.
 $Y_{k+1} = X_{k+1}$</p>
    </blockquote>
  </li>
</ul>

<p><img src="/assets/kalman_multi1.png" alt="image1" /><br />
X міИкЄ∞к∞ТмЭі(t=1) 1л°Ь м£ЉмЦім°МлЛ§. мЭі мГБнГЬмЧРмДЬ мЖНлПД к∞ТмЭА кіАмЄ°лРШмІА мХКмЬЉлѓАл°Ь мХМ мИШ мЧЖмЬЉлѓАл°Ь мЖНлПД л∞©нЦ•мЬЉл°ЬлКФ нБ∞ лґДмВ∞мЭД к∞ЦлКФлЛ§.(<code class="language-plaintext highlighter-rouge">нММлЮАмГЙ лґДнПђ</code>)</p>

