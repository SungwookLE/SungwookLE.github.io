<h2 id="3-кө¬нҳ„">3. кө¬нҳ„</h2>
<p><code class="language-plaintext highlighter-rouge">c++</code> кө¬нҳ„!<br />
м№јл§Ңн•„н„°лҠ” нҡЁкіјм Ғмқё мөңм Ғ(к°•кұҙ) н•„н„°мқҙлӢӨ.</p>

<h3 id="3-1-1м°Ёмӣҗ-м№јл§Ң">3-1. 1м°Ёмӣҗ м№јл§Ң</h3>
<p>1м°Ёмӣҗ м„ нҳ• м№јл§Ң, нқ”нһҲ ліҙлҠ” м№јл§Ң н•„н„° мҲҳмӢқ нҳ•нғңк°Җ м•„лӢҲкі  л¶„мӮ°мқҳ к°ҖмӨ‘м№ҳ нҸүк· мқ„ мқҙмҡ©н•ҳм—¬ к°’мқ„ ліҙм •н•ҳлҠ” нҳ•нғңлЎң мҲҳмӢқмқ„ мһ‘м„ұн•ҳмҳҖлӢӨ. мҲҳмӢқмқҳ нҳ•нғңл§Ң лӢӨлҘј лҝҗ <code class="language-plaintext highlighter-rouge">System Mtx A=1 мқҙкі , input Mtx B =1, Output Mtx C =1</code>мқё м№јл§Ңн•„н„°мҷҖ м •нҷ•нһҲ к°ҷлӢӨ.</p>
<div class="language-c++ highlighter-rouge"><div class="highlight"><pre class="highlight"><code><span class="k">template</span> <span class="o">&lt;</span><span class="k">typename</span> <span class="nc">T</span><span class="p">&gt;</span>
<span class="k">class</span> <span class="nc">Kalman</span><span class="p">{</span>
    <span class="nl">public:</span>
    <span class="n">Kalman</span><span class="p">(</span><span class="n">T</span> <span class="n">covariance_measurement_</span><span class="p">,</span> <span class="n">T</span> <span class="n">covariance_prediction_</span><span class="p">){</span>
        <span class="n">covariance_measurement</span> <span class="o">=</span> <span class="n">covariance_measurement_</span><span class="p">;</span>
        <span class="n">covariance_prediction</span> <span class="o">=</span> <span class="n">covariance_prediction_</span><span class="p">;</span>
    <span class="p">}</span>

    <span class="kt">void</span> <span class="n">measure_upate</span><span class="p">(</span><span class="n">T</span> <span class="n">mean_measure</span><span class="p">){</span>
        <span class="c1">// лІ мқҙмҰҲ лІ•м№ҷм—җ л”°лқј мЎ°кұҙл¶Җнҷ•лҘ м—җ л”°лқј м—…лҚ°мқҙнҠё лҗңлӢӨ.</span>
        <span class="n">T</span> <span class="n">mean_now</span> <span class="o">=</span> <span class="n">mean</span><span class="p">;</span>
        <span class="n">T</span> <span class="n">covariance_now</span> <span class="o">=</span> <span class="n">covariance</span><span class="p">;</span>


        <span class="n">T</span> <span class="n">new_covariance</span> <span class="o">=</span> <span class="mi">1</span><span class="o">/</span><span class="p">(</span><span class="mi">1</span><span class="o">/</span><span class="n">covariance_now</span><span class="o">+</span> <span class="mi">1</span><span class="o">/</span><span class="n">covariance_measurement</span> <span class="p">);</span>
        <span class="n">T</span> <span class="n">new_mean</span> <span class="o">=</span> <span class="p">(</span><span class="n">mean_now</span> <span class="o">*</span> <span class="mi">1</span><span class="o">/</span><span class="n">covariance_now</span> <span class="o">+</span> <span class="n">mean_measure</span><span class="o">*</span><span class="mi">1</span><span class="o">/</span><span class="n">covariance_measurement</span><span class="p">)</span>
                     <span class="o">/</span> <span class="p">(</span><span class="mi">1</span><span class="o">/</span><span class="n">new_covariance</span><span class="p">);</span>

        <span class="n">mean</span> <span class="o">=</span> <span class="n">new_mean</span><span class="p">;</span>
        <span class="n">covariance</span> <span class="o">=</span> <span class="n">new_covariance</span><span class="p">;</span>

        <span class="n">std</span><span class="o">::</span><span class="n">cout</span> <span class="o">&lt;&lt;</span> <span class="s">"update: "</span> <span class="o">&lt;&lt;</span> <span class="s">"["</span> <span class="o">&lt;&lt;</span> <span class="n">mean</span> <span class="o">&lt;&lt;</span> <span class="s">","</span> <span class="o">&lt;&lt;</span><span class="n">covariance</span> <span class="o">&lt;&lt;</span> <span class="s">"]"</span> <span class="o">&lt;&lt;</span> <span class="n">std</span><span class="o">::</span><span class="n">endl</span><span class="p">;</span>

    <span class="p">}</span>

    <span class="kt">void</span> <span class="n">model_prediction</span><span class="p">(</span><span class="n">T</span> <span class="n">input</span><span class="p">){</span>
        <span class="c1">//input мқҙ л“Өм–ҙмҳҙм—җ л”°лқј м „нҷ•лҘ  лІ•м№ҷм—җ мқҳкұ°н•ҳм—¬ м „мІҙ л¶„мӮ°мқҖ (+)к°Җ лҗңлӢӨ.</span>
        <span class="n">mean</span> <span class="o">=</span> <span class="n">mean</span> <span class="o">+</span> <span class="n">input</span><span class="p">;</span>
        <span class="n">covariance</span> <span class="o">=</span> <span class="n">covariance</span> <span class="o">+</span> <span class="n">covariance_prediction</span> <span class="p">;</span>

        <span class="n">std</span><span class="o">::</span><span class="n">cout</span> <span class="o">&lt;&lt;</span> <span class="s">"predict: "</span> <span class="o">&lt;&lt;</span> <span class="s">"["</span> <span class="o">&lt;&lt;</span> <span class="n">mean</span> <span class="o">&lt;&lt;</span> <span class="s">","</span> <span class="o">&lt;&lt;</span><span class="n">covariance</span> <span class="o">&lt;&lt;</span> <span class="s">"]"</span> <span class="o">&lt;&lt;</span> <span class="n">std</span><span class="o">::</span><span class="n">endl</span><span class="p">;</span>
    <span class="p">}</span>

    <span class="nl">private:</span>
    <span class="n">T</span> <span class="n">covariance_measurement</span><span class="p">;</span>
    <span class="n">T</span> <span class="n">covariance_prediction</span><span class="p">;</span>
    <span class="n">T</span> <span class="n">mean</span><span class="o">=</span><span class="mi">0</span><span class="p">;</span>
    <span class="n">T</span> <span class="n">covariance</span><span class="o">=</span><span class="mf">1000.0</span><span class="p">;</span>
<span class="p">};</span>

<span class="kt">int</span> <span class="nf">main</span><span class="p">(){</span>

    <span class="n">std</span><span class="o">::</span><span class="n">vector</span><span class="o">&lt;</span><span class="kt">double</span><span class="o">&gt;</span> <span class="n">inputs</span><span class="o">=</span><span class="p">{</span><span class="mi">1</span><span class="p">,</span><span class="mi">1</span><span class="p">,</span><span class="mi">2</span><span class="p">,</span><span class="mi">1</span><span class="p">,</span><span class="mi">1</span><span class="p">};</span>
    <span class="n">std</span><span class="o">::</span><span class="n">vector</span><span class="o">&lt;</span><span class="kt">double</span><span class="o">&gt;</span> <span class="n">measurements</span><span class="o">=</span><span class="p">{</span><span class="mi">5</span><span class="p">,</span><span class="mi">6</span><span class="p">,</span><span class="mi">7</span><span class="p">,</span><span class="mi">9</span><span class="p">,</span><span class="mi">10</span><span class="p">};</span>

    <span class="kt">double</span> <span class="n">measure_cov</span> <span class="o">=</span> <span class="mi">4</span><span class="p">;</span>
    <span class="kt">double</span> <span class="n">model_cov</span> <span class="o">=</span> <span class="mi">2</span><span class="p">;</span>

    <span class="n">Kalman</span><span class="o">&lt;</span><span class="kt">double</span><span class="o">&gt;</span> <span class="n">kf</span><span class="p">(</span><span class="n">measure_cov</span><span class="p">,</span> <span class="n">model_cov</span><span class="p">);</span>

    <span class="k">for</span><span class="p">(</span><span class="kt">int</span> <span class="n">i</span> <span class="o">=</span><span class="mi">0</span> <span class="p">;</span> <span class="n">i</span> <span class="o">&lt;</span> <span class="n">measurements</span><span class="p">.</span><span class="n">size</span><span class="p">();</span> <span class="o">++</span><span class="n">i</span><span class="p">){</span>
        <span class="n">kf</span><span class="p">.</span><span class="n">measure_upate</span><span class="p">(</span><span class="n">measurements</span><span class="p">[</span><span class="n">i</span><span class="p">]);</span>
        <span class="n">kf</span><span class="p">.</span><span class="n">model_prediction</span><span class="p">(</span><span class="n">inputs</span><span class="p">[</span><span class="n">i</span><span class="p">]);</span>
    <span class="p">}</span>

    <span class="k">return</span> <span class="mi">0</span><span class="p">;</span>
<span class="p">}</span>
</code></pre></div></div>

<h3 id="3-2-лӢӨм°Ёмӣҗ-м№јл§Ң">3-2. лӢӨм°Ёмӣҗ м№јл§Ң</h3>
<ul>
  <li>hidden state (observable)
лӢӨм°Ёмӣҗмқҳ StateлҘј м¶”м •н•  л•Ң, лӘЁл“  StateлҘј м¶”м •н•  мҲҳ мһҲлҠ” кІғмқҖ м•„лӢҲлӢӨ. лӮҳлҠ” м¶”м •кё°мҷҖ н•„н„°лҘј кө¬л¶„н•ҳм—¬ л¶ҖлҘҙлҠ” кІғмқ„ м„ нҳён•ҳлҠ”лҚ°, м¶”м •кё°лҠ” <code class="language-plaintext highlighter-rouge">observability</code>к°Җ мһҲм–ҙ мёЎм •к°’мңјлЎң лӮҙк°Җ кө¬н•ҳкі мһҗ н•ҳлҠ” stateлҘј мҙҲкё°к°’кіј кҙҖкі„м—Ҷмқҙ м¶”м •н•  мҲҳ мһҲлҠ” кҙҖмёЎкё°лҘј мқҳлҜён•ҳкі (observer), н•„н„°лҠ” <code class="language-plaintext highlighter-rouge">observability</code>к°Җ м—Ҷм–ҙ stateмқҳ л…ёмқҙмҰҲлҘј м ңкұ°н•ҳлҠ”(мҳҲмӢң: moving sum filter) м—ӯн• л§Ңмқ„ мҲҳн–үн•ҳлҠ” кІғмқ„ л§җн•ңлӢӨ. мқҙлҹ° кІҪмҡ° мҙҲкё°к°’мқҳ мҳӨм°ЁлҠ” к·№ліөмқҙ м•Ҳлҗҳкі  <code class="language-plaintext highlighter-rouge">costant error</code>лЎң мЎҙмһ¬н•ҳкІҢ лҗңлӢӨ.</li>
  <li>мҳҲлҘј л“Өм–ҙліҙл©ҙ, мҶҚлҸ„л§ҢмңјлЎң мң„м№ҳлҘј м¶”м •н•ҳкі мһҗ н•  л•Ң, мҙҲкё° мң„м№ҳлҘј лӘЁлҘҙл©ҙ м¶”м •н•ң мң„м№ҳлҠ” лӮҙк°Җ м„Өм •н•ң мҙҲкё° мң„м№ҳмҷҖ л¬јмІҙмқҳ мӢӨм ң мҙҲкё°мң„м№ҳ л§ҢнҒјмқҳ мҙҲкё° м—җлҹ¬к°Җ мЎҙмһ¬н•ҳлҠ”лҚ° мқҙлҠ” <code class="language-plaintext highlighter-rouge">constant error</code>лЎң лӮЁкІҢ лҗңлӢӨ.
observabilityлҠ” м„ нҳ•мӢңмҠӨн…ң мқҙлЎ мқ„ м°ёкі н•ҳкёё л°”лһҖлӢӨ. <code class="language-plaintext highlighter-rouge">dot_x = Ax+bu, y=Cx</code>лЎң мқҙлЈЁм–ҙм§„ м„ нҳ• мӢңмҠӨн…ңм—җм„ң AмҷҖ C mtxк°„мқҳ rank кҙҖкі„лҘј нҶөн•ң observable information м—¬л¶Җ(observability)лҠ” м–ҙл–»кІҢ нҷ•мқён•  мҲҳ мһҲкі  к°ңм„ лҗ  мҲҳ мһҲлҠ”м§Җ л°°мҡё мҲҳ мһҲлӢӨ.</li>
  <li>hidden stateлҠ” observable кҙҖкі„лҘј мқҙмҡ©н•ҳм—¬ м¶”м •н•  мҲҳ мһҲлҠ” stateлҘј л§җн•ҳкі  м¶”м •кё°лҠ” лҢҖл¶Җл¶„ м„јм„ңлЎң кі„мёЎмқҙ лҗҳм§Җ м•Ҳнқ”г„ҙ кІҪмҡ°м—җ н•„мҡ”н•ң кІҪмҡ°к°Җ л§Һм•„м„ң, мҡ°лҰ¬к°Җ н•„н„°к°Җ м•„лӢҢ м¶”м •кё°лҘј м„Өкі„н•  л–„лҠ” лҢҖл¶Җл¶„мқҳ кІҪмҡ°к°Җ <code class="language-plaintext highlighter-rouge">hidden state</code>лҘј м¶”м •н•ҳкё° мң„н•Ёмқҙлқјкі  ліј мҲҳ мһҲлӢӨ.</li>
  <li>мёЎм •к°’кіј лӘЁлҚёмқҙ Correlation кҙҖкі„м—җ мһҲлҠ” м№јл§Ң мӢңмҠӨн…ң л¶„мӮ° мқҙлҸҷ кіјм •мқ„ XлҠ” мў…л°©н–Ҙ мң„м№ҳ, $\dot X$лҠ” мў…л°©н–Ҙ мҶҚлҸ„мқҙкі , мёЎм •к°’мқҖ мў…л°©н–Ҙ мң„м№ҳ(X)мқё м•„лһҳ мҳҲмӢңлЎң мӮҙнҺҙліҙмһҗ.
    <blockquote>
      <p>лӘЁлҚё eq.
 ${X_{k+1} = X_k + dt* \dot X_k }$<br />
м•„мӣғн’Ӣ eq.
 $Y_{k+1} = X_{k+1}$</p>
    </blockquote>
  </li>
</ul>

<p><img src="/assets/kalman_multi1.png" alt="image1" /><br />
X мҙҲкё°к°’мқҙ(t=1) 1лЎң мЈјм–ҙмЎҢлӢӨ. мқҙ мғҒнғңм—җм„ң мҶҚлҸ„ к°’мқҖ кҙҖмёЎлҗҳм§Җ м•ҠмңјлҜҖлЎң м•Ң мҲҳ м—ҶмңјлҜҖлЎң мҶҚлҸ„ л°©н–ҘмңјлЎңлҠ” нҒ° л¶„мӮ°мқ„ к°–лҠ”лӢӨ.(<code class="language-plaintext highlighter-rouge">нҢҢлһҖмғү л¶„нҸ¬</code>)</p>

<p><img src="/assets/kalman_multi2.png" alt="image1" /><br />
(t=2) мқјл•Ң, мң„м№ҳк°Җ 2лЎң кҙҖмёЎлҗҳм—ҲлӢӨ(<code class="language-plaintext highlighter-rouge">Measure, мҙҲлЎқмғү л¶„нҸ¬</code>). м—¬кё°м„ң лӘЁлҚём—җ мқҳн•ҙ $\dot X_k$ мҶҚлҸ„лҠ” 1лЎң кі„мӮ°мқҙ лҗҳм–ҙ, лӘЁлҚё мҳҲмёЎк°’мқҙ мғқкё°кІҢ лҗңлӢӨ(<code class="language-plaintext highlighter-rouge">Prior, л№Ёк°„мғү л¶„нҸ¬</code>). мёЎм •лҗң мң„м№ҳм •ліҙ лҝҗ м•„лӢҲлқј, лӘЁлҚё мҳҲмёЎ м •ліҙлҸ„ мқҙмҡ©н•  мҲҳ мһҲкІҢ лҗң кІғмқҙлӢӨ. <code class="language-plaintext highlighter-rouge">Measure</code>мҷҖ <code class="language-plaintext highlighter-rouge">Prior</code>мқҳ ліҙм • Update кіјм •мқ„ нҶөн•ҙ м№јл§Ң мӢңмҠӨн…ңмқҳ л¶„мӮ°(<code class="language-plaintext highlighter-rouge">P, кІҖмқҖмғү л¶„нҸ¬</code>)мқҙ кі„мӮ°лҗҳкі , мқҙ кіјм •мқ„ л°ҳліөн•Ём—җ л”°лқј м№јл§Ң н•„н„°лҠ” л¬јмІҙмқҳ мң„м№ҳлҘј мһҳ м¶”м •н•ҳкІҢ лҗңлӢӨ. (<code class="language-plaintext highlighter-rouge">P, кІҖмқҖмғү л¶„нҸ¬</code>к°Җ м җм җ мҲҳл ҙн•Ё)</p>

<ul>
  <li>
    <p>к·ёлҰјмқ„ лӢӨмӢңн•ңлІҲ ліҙмһҗ. лӘЁлҚём—җм„  л№Ёк°„мғү лӘЁм–‘мңјлЎң 1м°Ё н•ЁмҲҳ нҳ•нғңмқҳ Prior л¶„мӮ°мқҙ мғқкё°кі , мёЎм •к°’м—җм„  мң„м№ҳл§Ң кі„мёЎн•ҳкі  мһҲмңјлӢҲ мҙҲлЎқмғү лӘЁм–‘мңјлЎң мҲҳм§Ғмқҳ Measure л¶„мӮ°мқ„ к°–кІҢ лҗңлӢӨ. м№јл§Ңн•„н„°лҠ” мқҙ л‘ҳмқҳ көҗм°Ём җм—җм„ң ліҙм •лҗҳлҠ” мғҲлЎңмҡҙ л¶„мӮ°мқ„ кі„мӮ°н•ҙлғ„мңјлЎңмҚЁ м¶”м • кІ°кіјлҘј ліҙм •н•ҳлҠ” кІғмқҙлӢӨ. лӘЁлҚёкіј мёЎм •к°’мқҳ correlation кҙҖкі„лҘј мқҙмҡ©н•ҳм—¬ ліҙм •мқҙ лҗңлӢӨ. к·ёлҰ¬кі  мӢңк°„мқҙ нқҗлҰ„м—җ л”°лқј ліҙм • кІ°кіјлҠ” лҚ”мҡұ лҚ” м •нҷ•н•ҙм§ҖкІҢ лҗңлӢӨ. <strong>insightлҘј мЈјлҠ” л¶Җл¶„мқҙлқјкі  мғқк°Ғн•ңлӢӨ. refлЎң м ңкіөн•ң udacity lectureлҘј н•ңлІҲ ліҙкё°лҘј м¶”мІңн•ңлӢӨ.</strong></p>
  </li>
  <li>
    <p>лӢӨм°Ёмӣҗ м№јл§Ңн•„н„°лҠ” м•„лһҳмҷҖ к°ҷмқҙ мҲҳмӢқ м •лҰ¬к°Җ лҗңлӢӨ. м•„лһҳмқҳ мҲҳмӢқмқҖ м •лҰ¬лҗң мөңмў… мҲҳмӢқмқҙлӢӨ.
<img src="https://www.mdpi.com/sustainability/sustainability-09-01868/article_deploy/html/images/sustainability-09-01868-g001-550.jpg" alt="image" /></p>
  </li>
  <li>
    <p><code class="language-plaintext highlighter-rouge">Eigen</code> лқјмқҙлёҢлҹ¬лҰ¬лҘј мқҙмҡ©н•ҳм—¬ м№јл§Ңн•„н„° кө¬нҳ„</p>
  </li>
</ul>

<div class="language-c++ highlighter-rouge"><div class="highlight"><pre class="highlight"><code><span class="cp">#include &lt;iostream&gt;
#include "Eigen/Dense"
</span>
<span class="k">class</span> <span class="nc">Kalman</span><span class="p">{</span>
    <span class="nl">public:</span>
    <span class="n">Kalman</span><span class="p">(</span><span class="kt">int</span> <span class="n">size</span><span class="p">,</span> <span class="kt">double</span> <span class="n">sampling_time</span><span class="p">,</span> <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span><span class="o">&amp;</span> <span class="n">_Ac</span><span class="p">,</span> <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span><span class="o">&amp;</span> <span class="n">_Bc</span><span class="p">,</span> <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span><span class="o">&amp;</span> <span class="n">_Cc</span><span class="p">,</span> <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span><span class="o">&amp;</span> <span class="n">_P</span><span class="p">,</span> <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span><span class="o">&amp;</span> <span class="n">_Q</span><span class="p">,</span> <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span><span class="o">&amp;</span> <span class="n">_R</span><span class="p">){</span>
        <span class="n">state_size</span> <span class="o">=</span> <span class="n">size</span><span class="p">;</span>
        <span class="n">dt</span> <span class="o">=</span> <span class="n">sampling_time</span><span class="p">;</span>

        <span class="n">Ad</span> <span class="o">=</span> <span class="n">_Ac</span> <span class="o">*</span> <span class="n">dt</span> <span class="o">+</span> <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span><span class="o">::</span><span class="n">Identity</span><span class="p">(</span><span class="n">size</span><span class="p">,</span> <span class="n">size</span><span class="p">);</span>
        <span class="n">Bd</span> <span class="o">=</span> <span class="n">_Bc</span> <span class="o">*</span> <span class="n">dt</span><span class="p">;</span>
        <span class="n">Cd</span> <span class="o">=</span> <span class="n">_Cc</span><span class="p">;</span>

        <span class="n">P</span> <span class="o">=</span> <span class="n">_P</span><span class="p">;</span>
        <span class="n">Q</span> <span class="o">=</span> <span class="n">_Q</span><span class="p">;</span>
        <span class="n">R</span> <span class="o">=</span> <span class="n">_R</span><span class="p">;</span>

        <span class="n">state</span> <span class="o">=</span> <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span><span class="o">::</span><span class="n">Zero</span><span class="p">(</span><span class="n">size</span><span class="p">,</span><span class="mi">1</span><span class="p">);</span>
    <span class="p">}</span>

    <span class="kt">void</span> <span class="n">model_prediction</span><span class="p">(</span><span class="kt">double</span> <span class="n">input</span><span class="p">){</span>

        <span class="n">state</span> <span class="o">=</span> <span class="n">Ad</span><span class="o">*</span><span class="n">state</span> <span class="o">+</span> <span class="n">Bd</span><span class="o">*</span><span class="n">input</span><span class="p">;</span>
        <span class="n">P</span> <span class="o">=</span> <span class="n">Ad</span><span class="o">*</span><span class="n">P</span><span class="o">*</span><span class="n">Ad</span><span class="p">.</span><span class="n">transpose</span><span class="p">()</span> <span class="o">+</span> <span class="n">Q</span><span class="p">;</span>
        
        <span class="n">std</span><span class="o">::</span><span class="n">cout</span> <span class="o">&lt;&lt;</span> <span class="s">"* predict: </span><span class="se">\n</span><span class="s">"</span><span class="p">;</span>
        <span class="n">std</span><span class="o">::</span><span class="n">cout</span> <span class="o">&lt;&lt;</span> <span class="s">"state(position , velocity) is </span><span class="se">\n</span><span class="s">"</span><span class="p">;</span>
        <span class="n">std</span><span class="o">::</span><span class="n">cout</span> <span class="o">&lt;&lt;</span> <span class="n">state</span> <span class="o">&lt;&lt;</span> <span class="n">std</span><span class="o">::</span><span class="n">endl</span><span class="p">;</span>
        <span class="n">std</span><span class="o">::</span><span class="n">cout</span> <span class="o">&lt;&lt;</span> <span class="s">"kalman covariance is </span><span class="se">\n</span><span class="s">"</span><span class="p">;</span>
        <span class="n">std</span><span class="o">::</span><span class="n">cout</span> <span class="o">&lt;&lt;</span> <span class="n">P</span> <span class="o">&lt;&lt;</span> <span class="n">std</span><span class="o">::</span><span class="n">endl</span> <span class="o">&lt;&lt;</span> <span class="n">std</span><span class="o">::</span><span class="n">endl</span><span class="p">;</span>        

    <span class="p">}</span>
    <span class="kt">void</span> <span class="n">measure_update</span><span class="p">(</span><span class="kt">double</span> <span class="n">measure</span><span class="p">){</span>

        <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span> <span class="n">meas</span><span class="p">(</span><span class="mi">1</span><span class="p">,</span><span class="mi">1</span><span class="p">);</span>
        <span class="n">meas</span> <span class="o">&lt;&lt;</span> <span class="n">measure</span><span class="p">;</span>
        
        <span class="n">K</span> <span class="o">=</span> <span class="n">P</span><span class="o">*</span><span class="n">Cd</span><span class="p">.</span><span class="n">transpose</span><span class="p">()</span><span class="o">*</span> <span class="p">(</span><span class="n">Cd</span><span class="o">*</span><span class="n">P</span><span class="o">*</span><span class="n">Cd</span><span class="p">.</span><span class="n">transpose</span><span class="p">()</span> <span class="o">+</span> <span class="n">R</span><span class="p">).</span><span class="n">inverse</span><span class="p">();</span>
        <span class="n">state</span> <span class="o">=</span> <span class="n">state</span> <span class="o">+</span> <span class="n">K</span><span class="o">*</span> <span class="p">(</span> <span class="n">meas</span> <span class="o">-</span> <span class="n">Cd</span><span class="o">*</span><span class="n">state</span><span class="p">);</span>
        <span class="n">P</span> <span class="o">=</span> <span class="n">P</span> <span class="o">-</span> <span class="n">K</span><span class="o">*</span><span class="n">Cd</span><span class="o">*</span><span class="n">P</span><span class="p">;</span>

        <span class="n">std</span><span class="o">::</span><span class="n">cout</span> <span class="o">&lt;&lt;</span> <span class="s">"** update: </span><span class="se">\n</span><span class="s">"</span><span class="p">;</span>
        <span class="n">std</span><span class="o">::</span><span class="n">cout</span> <span class="o">&lt;&lt;</span> <span class="s">"state(position , velocity) is </span><span class="se">\n</span><span class="s">"</span><span class="p">;</span>
        <span class="n">std</span><span class="o">::</span><span class="n">cout</span> <span class="o">&lt;&lt;</span> <span class="n">state</span> <span class="o">&lt;&lt;</span> <span class="n">std</span><span class="o">::</span><span class="n">endl</span><span class="p">;</span>
        <span class="n">std</span><span class="o">::</span><span class="n">cout</span> <span class="o">&lt;&lt;</span> <span class="s">"kalman covariance is </span><span class="se">\n</span><span class="s">"</span><span class="p">;</span>
        <span class="n">std</span><span class="o">::</span><span class="n">cout</span> <span class="o">&lt;&lt;</span> <span class="n">P</span> <span class="o">&lt;&lt;</span> <span class="n">std</span><span class="o">::</span><span class="n">endl</span> <span class="o">&lt;&lt;</span> <span class="n">std</span><span class="o">::</span><span class="n">endl</span><span class="p">;</span>
    <span class="p">}</span>

    <span class="nl">private:</span>
    <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span> <span class="n">state</span><span class="p">;</span>
    <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span> <span class="n">Ad</span><span class="p">;</span>
    <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span> <span class="n">Bd</span><span class="p">;</span>
    <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span> <span class="n">Cd</span><span class="p">;</span>
    
    <span class="kt">double</span> <span class="n">dt</span><span class="p">;</span>
    <span class="kt">int</span> <span class="n">state_size</span><span class="p">;</span>

    <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span> <span class="n">P</span><span class="p">,</span> <span class="n">Q</span><span class="p">,</span> <span class="n">R</span><span class="p">;</span>
    <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span> <span class="n">K</span><span class="p">;</span>
<span class="p">};</span>

<span class="kt">int</span> <span class="nf">main</span><span class="p">(){</span>

    <span class="c1">// м№јл§Ң мӢңмҠӨн…ң л§ӨнҠёлҰӯмҠӨ л°Ҹ л¶„мӮ°к°’ м„ёнҢ…</span>
    <span class="kt">int</span> <span class="n">size</span> <span class="o">=</span> <span class="mi">2</span><span class="p">;</span>
    <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span> <span class="n">Ac</span><span class="p">(</span><span class="n">size</span><span class="p">,</span><span class="n">size</span><span class="p">);</span>
    <span class="n">Ac</span> <span class="o">&lt;&lt;</span> <span class="mi">0</span><span class="p">,</span><span class="mi">1</span><span class="p">,</span><span class="mi">0</span><span class="p">,</span><span class="mi">0</span><span class="p">;</span>
    <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span> <span class="n">Bc</span><span class="p">(</span><span class="n">size</span><span class="p">,</span><span class="mi">1</span><span class="p">);</span>
    <span class="n">Bc</span> <span class="o">&lt;&lt;</span> <span class="mi">0</span><span class="p">,</span><span class="mi">1</span><span class="p">;</span>
    <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span> <span class="n">Cc</span><span class="p">(</span><span class="mi">1</span><span class="p">,</span><span class="n">size</span><span class="p">);</span>
    <span class="n">Cc</span> <span class="o">&lt;&lt;</span> <span class="mi">1</span><span class="p">,</span><span class="mi">0</span><span class="p">;</span>

    <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span> <span class="n">P</span><span class="p">(</span><span class="mi">2</span><span class="p">,</span><span class="mi">2</span><span class="p">);</span>
    <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span> <span class="n">Q</span><span class="p">(</span><span class="mi">2</span><span class="p">,</span><span class="mi">2</span><span class="p">);</span>
    <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span> <span class="n">R</span><span class="p">(</span><span class="mi">1</span><span class="p">,</span><span class="mi">1</span><span class="p">);</span>
    <span class="n">P</span> <span class="o">=</span> <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span><span class="o">::</span><span class="n">Identity</span><span class="p">(</span><span class="n">size</span><span class="p">,</span><span class="n">size</span><span class="p">)</span> <span class="o">*</span> <span class="mi">1000</span><span class="p">;</span>
    <span class="n">Q</span> <span class="o">=</span> <span class="n">Eigen</span><span class="o">::</span><span class="n">MatrixXd</span><span class="o">::</span><span class="n">Identity</span><span class="p">(</span><span class="n">size</span><span class="p">,</span><span class="n">size</span><span class="p">)</span> <span class="o">*</span> <span class="mi">0</span><span class="p">;</span>
    <span class="n">R</span> <span class="o">&lt;&lt;</span> <span class="mi">1</span><span class="p">;</span>

    <span class="c1">// м№јл§Ң н•„н„° RUN</span>
    <span class="n">Kalman</span> <span class="n">kf</span><span class="p">(</span><span class="mi">2</span><span class="p">,</span> <span class="mi">1</span><span class="p">,</span> <span class="n">Ac</span><span class="p">,</span> <span class="n">Bc</span><span class="p">,</span> <span class="n">Cc</span><span class="p">,</span> <span class="n">P</span><span class="p">,</span> <span class="n">Q</span><span class="p">,</span> <span class="n">R</span><span class="p">);</span>
    <span class="n">std</span><span class="o">::</span><span class="n">vector</span><span class="o">&lt;</span><span class="kt">double</span><span class="o">&gt;</span> <span class="n">inputs</span> <span class="o">=</span> <span class="p">{</span><span class="mi">2</span><span class="p">,</span><span class="mi">0</span><span class="p">,</span><span class="mi">0</span><span class="p">,</span><span class="mi">0</span><span class="p">};</span>
    <span class="n">std</span><span class="o">::</span><span class="n">vector</span><span class="o">&lt;</span><span class="kt">double</span><span class="o">&gt;</span> <span class="n">measures</span> <span class="o">=</span> <span class="p">{</span><span class="mi">1</span><span class="p">,</span><span class="mi">3</span><span class="p">,</span><span class="mi">5</span><span class="p">};</span>
    <span class="k">for</span> <span class="p">(</span><span class="kt">int</span> <span class="n">i</span> <span class="o">=</span> <span class="mi">0</span> <span class="p">;</span> <span class="n">i</span> <span class="o">&lt;</span> <span class="n">measures</span><span class="p">.</span><span class="n">size</span><span class="p">()</span> <span class="p">;</span> <span class="o">++</span><span class="n">i</span><span class="p">){</span>
        <span class="n">std</span><span class="o">::</span><span class="n">cout</span> <span class="o">&lt;&lt;</span> <span class="s">"=======&gt; Iter: "</span> <span class="o">&lt;&lt;</span> <span class="n">i</span><span class="o">+</span><span class="mi">1</span> <span class="o">&lt;&lt;</span> <span class="n">std</span><span class="o">::</span><span class="n">endl</span><span class="p">;</span>
        <span class="n">kf</span><span class="p">.</span><span class="n">model_prediction</span><span class="p">(</span><span class="n">inputs</span><span class="p">[</span><span class="n">i</span><span class="p">]);</span>
        <span class="n">kf</span><span class="p">.</span><span class="n">measure_update</span><span class="p">(</span><span class="n">measures</span><span class="p">[</span><span class="n">i</span><span class="p">]);</span>
    <span class="p">}</span>
    <span class="n">std</span><span class="o">::</span><span class="n">cout</span> <span class="o">&lt;&lt;</span> <span class="s">"=======&gt; Predict: "</span>  <span class="o">&lt;&lt;</span> <span class="n">std</span><span class="o">::</span><span class="n">endl</span><span class="p">;</span>
    <span class="n">kf</span><span class="p">.</span><span class="n">model_prediction</span><span class="p">(</span><span class="n">inputs</span><span class="p">.</span><span class="n">back</span><span class="p">());</span>

    <span class="k">return</span> <span class="mi">0</span><span class="p">;</span>
<span class="p">}</span>
